<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0E0B22">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {% endif %}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&family=Noto+Serif+SC:wght@300;400;500&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if settings.font_heading -%}{{ settings.font_heading | font_face }}{%- endif -%}
  {%- if settings.font_body -%}{{ settings.font_body | font_face }}{%- endif -%}

  <style>
    :root {
      {%- if settings.color_background != blank -%}--cream: {{ settings.color_background }};{%- endif -%}
      {%- if settings.color_text != blank -%}--brown: {{ settings.color_text }};{%- endif -%}
      {%- if settings.color_gold != blank -%}--gold: {{ settings.color_gold }}; --gold-light: color-mix(in srgb, {{ settings.color_gold }} 70%, white); --gold-dark: color-mix(in srgb, {{ settings.color_gold }} 80%, #000);{%- endif -%}
      {%- if settings.color_border != blank -%}--border: {{ settings.color_border }};{%- endif -%}
      {%- if settings.color_header_bg != blank -%}--header-bg: {{ settings.color_header_bg }};{%- endif -%}
      {%- if settings.color_header_text != blank -%}--header-text: {{ settings.color_header_text }};{%- endif -%}
      {%- if settings.color_footer_bg != blank -%}--footer-bg: {{ settings.color_footer_bg }};{%- endif -%}
      {%- if settings.color_footer_text != blank -%}--footer-text: {{ settings.color_footer_text }};{%- endif -%}
      {%- if settings.color_button_bg != blank -%}--btn-bg: {{ settings.color_button_bg }};{%- endif -%}
      {%- if settings.color_button_text != blank -%}--btn-text: {{ settings.color_button_text }};{%- endif -%}
      {%- if settings.font_heading -%}--font-serif: {{ settings.font_heading.family }}, Georgia, serif;{%- endif -%}
      {%- if settings.font_body -%}--font-sans: {{ settings.font_body.family }}, sans-serif;{%- endif -%}
      {%- if settings.font_body_size -%}font-size: {{ settings.font_body_size }}px;{%- endif -%}

      {%- comment %} Global background image — stacked over a dark overlay so all sections see it {%- endcomment -%}
      {%- if settings.bg_image != blank -%}
        {%- assign overlay_alpha = settings.bg_overlay | default: 55 | divided_by: 100.0 -%}
        --bg-image: url('{{ settings.bg_image | image_url: width: 2000 }}');
        --bg-overlay: {{ overlay_alpha }};
      {%- else -%}
        --bg-image: none;
        --bg-overlay: 0;
      {%- endif -%}
      --bg-attachment: {%- if settings.bg_fixed %}fixed{%- else %}scroll{%- endif -%};
    }
  </style>

  <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
</head>

<body>

  <!-- Mobile Nav Overlay -->
  <div class="nav-drawer__overlay" aria-hidden="true"></div>

  <!-- Mobile Nav Drawer -->
  <nav class="nav-drawer" aria-label="Mobile navigation">
    <div class="nav-drawer__close">
      <button aria-label="Close menu">
        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="nav-drawer__links">
      {%- assign mobile_menu_handle = settings.main_menu | default: 'main-menu' -%}
      {%- assign mobile_links = linklists[mobile_menu_handle].links -%}
      {%- if mobile_links.size > 0 -%}
        {%- for link in mobile_links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        {%- for link in linklists['main-menu'].links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </nav>

  {% sections 'header-group' %}

  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% sections 'global-group' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
