<div class="password-page-wrap">
  <div class="password-page">

    <div class="password-page__brand">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 240 }}"
             alt="{{ shop.name }}"
             class="password-page__logo-img"
             width="120">
      {%- else -%}
        <h1 class="password-page__brand-text">{{ shop.name }}</h1>
      {%- endif -%}
    </div>

    <div class="password-page__card">
      {%- if section.settings.eyebrow != blank -%}
        <p class="password-page__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="password-page__title">{{ section.settings.heading }}</h2>

      {%- if section.settings.subtext != blank -%}
        <p class="password-page__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.show_email_form -%}
        <div class="password-page__notify">
          {%- form 'customer', class: 'password-page__form' -%}
            <input type="hidden" name="contact[tags]" value="prospect, password-page">
            <label for="password-notify-email" class="password-page__form-label">
              {{ section.settings.notify_label }}
            </label>
            <div class="password-page__form-row">
              <input type="email"
                     id="password-notify-email"
                     name="contact[email]"
                     placeholder="{{ section.settings.email_placeholder }}"
                     required
                     class="password-page__input">
              <button type="submit" class="password-page__btn">
                {{ section.settings.email_btn }}
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="password-page__success">{{ section.settings.success_msg }}</p>
            {%- endif -%}
            {%- if form.errors -%}
              <p class="password-page__error">{{ form.errors | default_errors }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    <div class="password-page__unlock">
      <details class="password-page__details">
        <summary class="password-page__details-summary">
          <span>{{ section.settings.enter_label }}</span>
          <svg viewBox="0 0 16 16" width="12" height="12" class="password-page__details-arrow">
            <polyline points="4,6 8,10 12,6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="password-page__unlock-form">
          {%- form 'storefront_password' -%}
            <div class="password-page__form-row">
              <input type="password"
                     name="password"
                     placeholder="{{ section.settings.password_placeholder }}"
                     class="password-page__input"
                     autocomplete="off"
                     required>
              <button type="submit" class="password-page__btn password-page__btn--ghost">
                {{ section.settings.unlock_label }}
              </button>
            </div>
            {%- if form.errors -%}
              <p class="password-page__error">Incorrect password — please try again.</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </details>
    </div>

    <p class="password-page__powered">Crafted with intention · {{ 'now' | date: "%Y" }}</p>

  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "password-section",
  "settings": [
    { "type": "image_picker", "id": "logo",     "label": "Logo image" },
    { "type": "text",         "id": "eyebrow",  "label": "Eyebrow",  "default": "Coming Soon" },
    { "type": "text",         "id": "heading",  "label": "Heading",  "default": "Something Beautiful Is Coming" },
    { "type": "textarea",     "id": "subtext",  "label": "Subtext",  "default": "We're preparing an exquisite collection of crystal energy jewelry. Be the first to know when we launch." },
    { "type": "header",       "content": "Email notification form" },
    { "type": "checkbox",     "id": "show_email_form",  "label": "Show email form", "default": true },
    { "type": "text",         "id": "notify_label",     "label": "Form label",      "default": "Get notified when we launch" },
    { "type": "text",         "id": "email_placeholder","label": "Email placeholder","default": "you@email.com" },
    { "type": "text",         "id": "email_btn",        "label": "Subscribe button", "default": "Notify Me" },
    { "type": "text",         "id": "success_msg",      "label": "Success message",  "default": "Thank you — we'll be in touch soon." },
    { "type": "header",       "content": "Password access" },
    { "type": "text",         "id": "enter_label",      "label": "Enter password label",  "default": "Enter using password" },
    { "type": "text",         "id": "password_placeholder","label": "Password placeholder","default": "Password" },
    { "type": "text",         "id": "unlock_label",     "label": "Unlock button",        "default": "Enter" }
  ]
}
{% endschema %}
