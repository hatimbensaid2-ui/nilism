<section class="list-collections-section">
  <div class="container">
    <header class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="section-heading__title">{{ section.settings.heading | default: 'All Collections' }}</h1>
    </header>
    <div class="collections-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collection-tile">
          <div class="collection-tile__image">
            {%- if collection.image != blank -%}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title }}" loading="lazy">
            {%- elsif collection.products.first.featured_image != blank -%}
              <img src="{{ collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ collection.title }}" loading="lazy">
            {%- else -%}
              <div class="collection-tile__placeholder">
                <svg width="60" height="60" viewBox="0 0 140 80"><ellipse cx="70" cy="40" rx="55" ry="22" fill="none" stroke="#C4A070" stroke-width="2"/><circle cx="70" cy="18" r="7" fill="#D0AE84"/><circle cx="70" cy="62" r="7" fill="#CCAA7A"/></svg>
              </div>
            {%- endif -%}
          </div>
          <div class="collection-tile__body">
            <h3 class="collection-tile__title">{{ collection.title }}</h3>
            <p class="collection-tile__count">{{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "class": "list-collections-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "All Collections" }
  ],
  "presets": [{ "name": "Collections list" }]
}
{% endschema %}
