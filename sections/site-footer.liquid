<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">

    <div class="site-footer__brand">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="site-footer__logo-link">
          <img src="{{ section.settings.logo | image_url: width: 200 }}"
               alt="{{ section.settings.brand_title | default: shop.name }}"
               width="{{ section.settings.logo_width }}"
               loading="lazy">
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="site-footer__brand-name">
          {{ section.settings.brand_title | default: shop.name }}
        </a>
      {%- endif -%}
      <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
      <div class="site-footer__social">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 3h-3v10a4 4 0 11-4-4V6a7 7 0 007 7V3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" aria-label="Pinterest" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.76 1.22-5.17 1.22-5.17s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.57 2.25-.87 3.5-.25 1.05.52 1.9 1.55 1.9 1.86 0 3.11-2.37 3.11-5.17 0-2.14-1.44-3.64-3.5-3.64-2.38 0-3.78 1.79-3.78 3.63 0 .72.28 1.49.62 1.91a.25.25 0 01.06.24l-.23.95c-.04.14-.12.18-.28.11-1.04-.48-1.69-2-1.69-3.22 0-2.62 1.9-5.03 5.49-5.03 2.88 0 5.12 2.05 5.12 4.79 0 2.86-1.8 5.16-4.3 5.16-.84 0-1.63-.44-1.9-.95l-.52 1.94c-.19.72-.69 1.62-1.03 2.17.78.24 1.6.37 2.46.37 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div>
      <p class="site-footer__col-title">{{ section.settings.col2_title }}</p>
      <ul class="site-footer__links">
        {%- assign col2_links = linklists[section.settings.menu_col2].links -%}
        {%- if col2_links.size > 0 -%}
          {%- for link in col2_links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}
        {%- else -%}
          <li><a href="/collections/all">All Crystals</a></li>
          <li><a href="/collections">Collections</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div>
      <p class="site-footer__col-title">{{ section.settings.col3_title }}</p>
      <ul class="site-footer__links">
        {%- assign col3_links = linklists[section.settings.menu_col3].links -%}
        {%- if col3_links.size > 0 -%}
          {%- for link in col3_links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}
        {%- else -%}
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/blogs/news">Crystal Guide</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div>
      <p class="site-footer__col-title">{{ section.settings.col4_title }}</p>
      <ul class="site-footer__links">
        {%- assign col4_links = linklists[section.settings.menu_col4].links -%}
        {%- if col4_links.size > 0 -%}
          {%- for link in col4_links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}
        {%- else -%}
          <li><a href="/policies/shipping-policy">Shipping</a></li>
          <li><a href="/policies/refund-policy">Returns</a></li>
        {%- endif -%}
        {%- if section.settings.contact_email != blank -%}
          <li><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></li>
        {%- endif -%}
      </ul>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p class="site-footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="site-footer__payment-icons">
      <svg viewBox="0 0 46 30" width="46" height="24" aria-label="Visa"><rect width="46" height="30" rx="4" fill="#1A1F71"/><text x="23" y="21" text-anchor="middle" font-size="13" font-family="Arial" font-weight="700" fill="white" letter-spacing="1">VISA</text></svg>
      <svg viewBox="0 0 46 30" width="46" height="24" aria-label="Mastercard"><rect width="46" height="30" rx="4" fill="#252525"/><circle cx="18" cy="15" r="8" fill="#EB001B"/><circle cx="28" cy="15" r="8" fill="#F79E1B"/><path d="M23 8.6a8 8 0 010 12.8A8 8 0 0123 8.6z" fill="#FF5F00"/></svg>
      <svg viewBox="0 0 46 30" width="46" height="24" aria-label="PayPal"><rect width="46" height="30" rx="4" fill="#F5F7FA"/><text x="23" y="19" text-anchor="middle" font-size="10" font-family="Arial" font-weight="700" fill="#003087">Pay<tspan fill="#009CDE">Pal</tspan></text></svg>
      <svg viewBox="0 0 46 30" width="46" height="24" aria-label="American Express"><rect width="46" height="30" rx="4" fill="#2E77BC"/><text x="23" y="14" text-anchor="middle" font-size="6" font-family="Arial" font-weight="700" fill="white">AMERICAN</text><text x="23" y="22" text-anchor="middle" font-size="6" font-family="Arial" font-weight="700" fill="white">EXPRESS</text></svg>
      <svg viewBox="0 0 46 30" width="46" height="24" aria-label="Shop Pay"><rect width="46" height="30" rx="4" fill="#5A31F4"/><text x="23" y="19" text-anchor="middle" font-size="8" font-family="Arial" font-weight="700" fill="white">Shop Pay</text></svg>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_width", "label": "Logo width (px)", "min": 60, "max": 260, "step": 10, "default": 140 },
    { "type": "text", "id": "brand_title", "label": "Brand name", "info": "Shown if no logo is uploaded. Defaults to shop name." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Crystal energy jewelry curated for your journey." },
    { "type": "header", "content": "Social links" },
    { "type": "url", "id": "instagram_url", "label": "Instagram" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok" },
    { "type": "url", "id": "facebook_url", "label": "Facebook" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest" },
    { "type": "header", "content": "Columns" },
    { "type": "text", "id": "col2_title", "label": "Column 2 title", "default": "Shop" },
    { "type": "link_list", "id": "menu_col2", "label": "Column 2 menu" },
    { "type": "text", "id": "col3_title", "label": "Column 3 title", "default": "Learn" },
    { "type": "link_list", "id": "menu_col3", "label": "Column 3 menu" },
    { "type": "text", "id": "col4_title", "label": "Column 4 title", "default": "Support" },
    { "type": "link_list", "id": "menu_col4", "label": "Column 4 menu" },
    { "type": "text", "id": "contact_email", "label": "Contact email" }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
