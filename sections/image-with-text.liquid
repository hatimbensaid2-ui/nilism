<section class="image-with-text section-{{ section.id }}"
  style="{% if section.settings.bg_color != blank %}background:{{ section.settings.bg_color }};{% endif %}">

  <div class="image-with-text__inner{% if section.settings.image_position == 'right' %} image-with-text__inner--reverse{% endif %}">

    <!-- Media -->
    <div class="image-with-text__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 500 }} 500w,
                  {{ section.settings.image | image_url: width: 800 }} 800w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          loading="lazy"
        >
      {%- else -%}
        <div style="
          width:100%; height:100%; min-height:520px;
          background: linear-gradient(145deg, var(--cream-dark) 0%, var(--cream) 100%);
          display:flex; align-items:center; justify-content:center;
        ">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--border)" stroke-width="0.8">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

    <!-- Content -->
    <div class="image-with-text__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="image-with-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="image-with-text__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="image-with-text__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="image-with-text__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'list_item' and block.settings.text != blank -%}
              <li class="image-with-text__list-item" {{ block.shopify_attributes }}>
                <span class="image-with-text__list-icon">
                  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {{ block.settings.text }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--{{ section.settings.button_style }}">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "image-with-text-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "image_position", "label": "Image position",
      "options": [
        { "value": "left",  "label": "Image left"  },
        { "value": "right", "label": "Image right" }
      ],
      "default": "left"
    },
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",  "default": "Handcrafted" },
    { "type": "text",     "id": "heading",  "label": "Heading",  "default": "The Art of Crystal Healing" },
    { "type": "richtext", "id": "body",     "label": "Body text","default": "<p>Our master artisans select each stone by hand, ensuring only the finest quality crystals reach you — each one holding centuries of Earth's energy.</p>" },
    {
      "type": "text", "id": "button_label", "label": "Button label", "default": "Learn More"
    },
    { "type": "url", "id": "button_link",  "label": "Button link", "default": "/pages/about" },
    {
      "type": "select", "id": "button_style", "label": "Button style",
      "options": [
        { "value": "outline-gold",  "label": "Outline Gold"  },
        { "value": "solid-gold",    "label": "Solid Gold"    },
        { "value": "outline-brown", "label": "Outline Brown" }
      ],
      "default": "outline-gold"
    },
    { "type": "color", "id": "bg_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List item",
      "settings": [
        { "type": "text", "id": "text", "label": "Item text", "default": "Ethically sourced from certified mines" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Text",
      "blocks": [
        { "type": "list_item", "settings": { "text": "Ethically sourced from certified mines" } },
        { "type": "list_item", "settings": { "text": "Master-cleansed and energetically programmed" } },
        { "type": "list_item", "settings": { "text": "Handstrung on stretch cord for lasting wear" } }
      ]
    }
  ]
}
{% endschema %}
