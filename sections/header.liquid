<header class="site-header" role="banner">
  <div class="site-header__inner">

    <!-- Mobile Menu Toggle -->
    <button class="site-header__mobile-toggle" aria-label="Open menu" aria-expanded="false">
      <svg viewBox="0 0 24 24"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
    </button>

    <!-- Desktop Nav (left) -->
    <nav class="site-header__nav" role="navigation" aria-label="Main menu">
      {%- for link in linklists[section.settings.main_menu].links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <!-- Logo (center) -->
    <div class="site-header__logo">
      <a href="/" aria-label="{{ shop.name }} — home">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            loading="eager"
          >
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Actions (right) -->
    <div class="site-header__actions">
      <button class="site-header__icon-btn site-header__icon-btn--search" aria-label="Search" onclick="document.querySelector('#search-modal').showModal()">
        <svg viewBox="0 0 24 24"><circle cx="10.5" cy="10.5" r="6.5"/><line x1="15.5" y1="15.5" x2="22" y2="22"/></svg>
        <span>Search</span>
      </button>

      <a href="{{ routes.account_url }}" class="site-header__icon-btn site-header__icon-btn--account" aria-label="Account">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        <span>Account</span>
      </a>

      <!-- Language Switcher -->
      {%- if shop.published_locales.size > 1 -%}
        <div class="lang-switcher" aria-label="Language selector">
          {%- form 'localization', id: 'HeaderLocalizationForm' -%}
            <select
              name="locale_code"
              aria-label="Select language"
              onchange="this.form.submit()"
            >
              {%- for locale in shop.published_locales -%}
                <option
                  value="{{ locale.iso_code }}"
                  {%- if locale.iso_code == request.locale.iso_code %} selected{%- endif -%}
                >
                  {%- case locale.iso_code -%}
                    {%- when 'en' -%}EN
                    {%- when 'zh-CN' -%}中文
                    {%- when 'zh-TW' -%}繁體
                    {%- when 'ja' -%}日本語
                    {%- else -%}{{ locale.iso_code | upcase }}
                  {%- endcase -%}
                </option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        </div>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="site-header__icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count" aria-label="{{ cart.item_count }} items in cart">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

<!-- Search Modal -->
<dialog id="search-modal" style="position:fixed;inset:0;width:100%;max-width:100%;border:none;background:rgba(0,0,20,0.75);display:none;padding:0;margin:0;backdrop-filter:blur(6px);" onclick="if(event.target===this)this.close()">
  <div style="background:#160F2E;border:1px solid #261A55;max-width:600px;margin:80px auto;padding:32px;position:relative;box-shadow:0 20px 60px rgba(0,0,80,0.5);">
    <button onclick="document.querySelector('#search-modal').close()" style="position:absolute;top:12px;right:12px;background:none;border:none;font-size:1.4rem;cursor:pointer;color:#F0E8D4;">&times;</button>
    <form action="{{ routes.search_url }}" method="get" style="display:flex;gap:0;">
      <input type="search" name="q" placeholder="Search crystals, bracelets..." style="flex:1;padding:12px 16px;border:1px solid #261A55;border-right:none;background:#0E0B22;color:#F0E8D4;font-family:var(--font-sans);font-size:0.9rem;outline:none;">
      <button type="submit" style="padding:12px 20px;background:#C9963B;border:none;color:#07041A;cursor:pointer;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#07041A" stroke-width="1.5"><circle cx="10.5" cy="10.5" r="6.5"/><line x1="15.5" y1="15.5" x2="22" y2="22"/></svg>
      </button>
    </form>
  </div>
</dialog>
<script>
  document.getElementById('search-modal').addEventListener('click', function(e){
    if(e.target===this){ this.close(); this.style.display='none'; }
  });
  document.querySelectorAll('[onclick*="search-modal"]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var m = document.getElementById('search-modal');
      m.style.display='block';
      m.showModal && m.showModal();
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "site-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 240,
      "step": 8,
      "default": 160,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
