<section class="shop-by-intention section-{{ section.id }}">
  <div class="container">

    <div class="section-heading">
      <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="intention-grid">
      {%- for block in section.blocks -%}
        <div class="intention-card" {{ block.shopify_attributes }}>

          <div class="intention-card__image-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 600 }} 600w"
                sizes="(max-width: 768px) 100vw, 33vw"
                alt="{{ block.settings.image.alt | default: block.settings.title_zh }}"
                loading="lazy"
                width="600"
                height="450"
              >
            {%- else -%}
              {%- assign bg_colors = '#E8D8C8,#E0D0C0,#D8C8B8' | split: ',' -%}
              {%- assign bg = bg_colors[forloop.index0] -%}
              <div style="width:100%;height:100%;background:{{ bg }};display:flex;align-items:center;justify-content:center;">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#B89878" stroke-width="0.8" opacity="0.5">
                  <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <div class="intention-card__body">

            <!-- Icon -->
            <div class="intention-card__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'lotus' -%}
                  <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 28c0 0-8-5-8-12 0-3.3 2.7-6 6-6 1.1 0 2.1.3 3 .8" fill="none" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M18 28c0 0 8-5 8-12 0-3.3-2.7-6-6-6-1.1 0-2.1.3-3 .8" fill="none" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M18 28c0-8 0-14 0-18" fill="none" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M10 20c-4-2-5-7-3-10 2-2 5-2 7-.5" fill="none" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M26 20c4-2 5-7 3-10-2-2-5-2-7-.5" fill="none" stroke="currentColor" stroke-width="1.2"/>
                    <ellipse cx="18" cy="8" rx="2.5" ry="3.5" fill="none" stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 30l-1.5-1.4C8 20.6 3 16.3 3 11A7 7 0 0110 4c2.4 0 4.7 1.1 6.2 2.8L18 8.5l1.8-1.7C21.3 5.1 23.6 4 26 4a7 7 0 017 7c0 5.3-5 9.6-13.5 17.6L18 30z" fill="currentColor" opacity="0.85"/>
                  </svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 3l13 5v8c0 8-6 14-13 17C11 30 5 24 5 16V8L18 3z" fill="none" stroke="currentColor" stroke-width="1.3"/>
                    <polyline points="13,17 16,20 23,13" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                    <polygon points="18,3 22,13 33,13 24,20 27,31 18,24 9,31 12,20 3,13 14,13" fill="none" stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="18" cy="18" r="12" fill="none" stroke="currentColor" stroke-width="1.2"/>
                    <circle cx="18" cy="18" r="4" fill="currentColor" opacity="0.6"/>
                  </svg>
              {%- endcase -%}
            </div>

            {%- if block.settings.title_zh != blank -%}
              <h3 class="intention-card__title-zh">{{ block.settings.title_zh }}</h3>
            {%- endif -%}

            {%- if block.settings.subtitle_zh != blank -%}
              <p class="intention-card__subtitle-zh">{{ block.settings.subtitle_zh }}</p>
            {%- endif -%}

            {%- if block.settings.description_en != blank -%}
              <p class="intention-card__desc-en">{{ block.settings.description_en }}</p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="intention-card__btn">
                {{ block.settings.button_label }}
                <span class="intention-card__btn-arrow">&#8964;</span>
              </a>
            {%- endif -%}

          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Shop by Intention",
  "tag": "section",
  "class": "shop-by-intention-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Intention"
    }
  ],
  "blocks": [
    {
      "type": "intention_card",
      "name": "Intention Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bracelet image"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lotus",  "label": "Lotus (Wealth)" },
            { "value": "heart",  "label": "Heart (Love)" },
            { "value": "shield", "label": "Shield (Protection)" },
            { "value": "star",   "label": "Star" },
            { "value": "circle", "label": "Circle" }
          ],
          "default": "lotus"
        },
        {
          "type": "text",
          "id": "title_zh",
          "label": "Title",
          "default": "Wealth"
        },
        {
          "type": "text",
          "id": "subtitle_zh",
          "label": "Subtitle",
          "default": "财富 · Attract Abundance"
        },
        {
          "type": "text",
          "id": "description_en",
          "label": "Description",
          "default": "Invite wealth, career breakthroughs, and financial flow into your life."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Explore →"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link",
          "default": "/collections/wealth"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Intention",
      "blocks": [
        {
          "type": "intention_card",
          "settings": {
            "icon": "lotus",
            "title_zh": "Wealth",
            "subtitle_zh": "财富 · Attract Abundance",
            "description_en": "Invite wealth, career breakthroughs, and financial flow into your life.",
            "button_label": "Explore →",
            "button_link": "/collections/wealth"
          }
        },
        {
          "type": "intention_card",
          "settings": {
            "icon": "heart",
            "title_zh": "Love",
            "subtitle_zh": "正缘 · Attract Your Person",
            "description_en": "Open your heart to genuine connection, romance, and relationship harmony.",
            "button_label": "Explore →",
            "button_link": "/collections/love"
          }
        },
        {
          "type": "intention_card",
          "settings": {
            "icon": "shield",
            "title_zh": "Protection",
            "subtitle_zh": "保护 · Shield Your Energy",
            "description_en": "Ward off negative energy, guard your aura, and move through the world with confidence.",
            "button_label": "Explore →",
            "button_link": "/collections/protection"
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
