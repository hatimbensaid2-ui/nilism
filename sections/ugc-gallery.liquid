<section class="ugc-gallery-section section-{{ section.id }}">
  <div class="container">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.handle != blank -%}
        <p class="ugc-gallery__handle">{{ section.settings.handle }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="ugc-gallery">
    {%- for block in section.blocks -%}
      <a
        class="ugc-item"
        href="{{ block.settings.link | default: '#' }}"
        {{ block.shopify_attributes }}
        aria-label="Customer photo {{ forloop.index }}"
      >
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 400 }}"
            alt="{{ block.settings.caption | default: 'Customer photo' }}"
            loading="lazy"
            width="400" height="400"
          >
        {%- else -%}
          {%- assign ugc_bgs = '#E8D8C8,#EDE0D8,#D8D0D8,#E0DDF0,#DCE8D8,#F0E8D4,#D8E4EC,#F0DCD8' | split: ',' -%}
          <div style="width:100%;height:100%;background:{{ ugc_bgs[forloop.index0] }};display:flex;align-items:center;justify-content:center;aspect-ratio:1;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#B8936A" stroke-width="0.8" opacity="0.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        {%- endif -%}
        <div class="ugc-item__overlay">
          {%- if block.settings.caption != blank -%}
            <p class="ugc-item__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
          <span class="ugc-item__icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none"/></svg>
          </span>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_label != blank -%}
    <div style="text-align:center;margin-top:40px;">
      <a href="{{ section.settings.cta_link | default: '#' }}" class="btn btn--outline-gold">
        {{ section.settings.cta_label }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "UGC / Instagram Gallery",
  "tag": "section",
  "class": "ugc-gallery-wrap",
  "settings": [
    { "type": "text", "id": "eyebrow",   "label": "Eyebrow",    "default": "Real People. Real Energy." },
    { "type": "text", "id": "heading",   "label": "Heading",    "default": "Tag Us @AoSharma" },
    { "type": "text", "id": "handle",    "label": "Handle text","default": "#AoSharmaCrystals" },
    { "type": "text", "id": "cta_label", "label": "CTA label",  "default": "Follow on Instagram" },
    { "type": "url",  "id": "cta_link",  "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image",   "label": "Photo" },
        { "type": "text",         "id": "caption", "label": "Caption (hover text)" },
        { "type": "url",          "id": "link",    "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Gallery",
      "blocks": [
        { "type": "photo" }, { "type": "photo" }, { "type": "photo" },
        { "type": "photo" }, { "type": "photo" }, { "type": "photo" }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
