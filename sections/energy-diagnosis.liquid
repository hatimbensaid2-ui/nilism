<div class="energy-diag" id="energy-diag-{{ section.id }}">

  <!-- Corner ornaments -->
  <span class="energy-diag__corner energy-diag__corner--tl" aria-hidden="true"></span>
  <span class="energy-diag__corner energy-diag__corner--tr" aria-hidden="true"></span>
  <span class="energy-diag__corner energy-diag__corner--bl" aria-hidden="true"></span>
  <span class="energy-diag__corner energy-diag__corner--br" aria-hidden="true"></span>

  <!-- Header -->
  <div class="energy-diag__header">
    <h2 class="energy-diag__title">{{ section.settings.title }}</h2>
    <p class="energy-diag__subtitle">{{ section.settings.subtitle }}</p>
  </div>

  <!-- 3-column grid -->
  <div class="energy-diag__grid">

    <!-- Column 1 -->
    <div class="energy-diag__col">
      <div class="energy-diag__step"><span>1</span></div>
      <p class="energy-diag__question">{{ section.settings.q1_label }}</p>
      <div class="energy-diag__options" role="radiogroup">
        {%- assign q1_opts = section.settings.q1_options | split: '|' -%}
        {%- assign q1_tags = section.settings.q1_tags | split: '|' -%}
        {%- assign q1_icons = 'office,bed,family' | split: ',' -%}
        {%- for opt in q1_opts -%}
          <label class="energy-diag__option">
            <input type="radio" name="q1-{{ section.id }}" value="{{ q1_tags[forloop.index0] }}" class="energy-diag__radio">
            <span class="energy-diag__option-dot"></span>
            <span class="energy-diag__option-icon" aria-hidden="true">
              {%- case q1_icons[forloop.index0] -%}
                {%- when 'office' -%}
                  <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="7" r="3"/><path d="M5 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/><line x1="3" y1="19" x2="19" y2="19" stroke-width="1"/></svg>
                {%- when 'bed' -%}
                  <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="2" y="10" width="18" height="7" rx="1"/><path d="M2 17v2M20 17v2"/><path d="M2 13h18"/><path d="M6 13V9a2 2 0 012-2h6a2 2 0 012 2v4"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="2"/><line x1="11" y1="2" x2="11" y2="5"/><line x1="11" y1="17" x2="11" y2="20"/><line x1="2" y1="11" x2="5" y2="11"/><line x1="17" y1="11" x2="20" y2="11"/><line x1="4.9" y1="4.9" x2="7" y2="7"/><line x1="15" y1="15" x2="17.1" y2="17.1"/><line x1="4.9" y1="17.1" x2="7" y2="15"/><line x1="15" y1="7" x2="17.1" y2="4.9"/></svg>
              {%- endcase -%}
            </span>
            <span class="energy-diag__option-text">{{ opt }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    <!-- Column 2 -->
    <div class="energy-diag__col">
      <div class="energy-diag__step"><span>2</span></div>
      <p class="energy-diag__question">{{ section.settings.q2_label }}</p>
      <div class="energy-diag__options" role="radiogroup">
        {%- assign q2_opts = section.settings.q2_options | split: '|' -%}
        {%- assign q2_tags = section.settings.q2_tags | split: '|' -%}
        {%- assign q2_icons = 'wealth,love,shield' | split: ',' -%}
        {%- for opt in q2_opts -%}
          <label class="energy-diag__option">
            <input type="radio" name="q2-{{ section.id }}" value="{{ q2_tags[forloop.index0] }}" class="energy-diag__radio">
            <span class="energy-diag__option-dot"></span>
            <span class="energy-diag__option-icon" aria-hidden="true">
              {%- case q2_icons[forloop.index0] -%}
                {%- when 'wealth' -%}
                  <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="8"/><path d="M11 7v1m0 6v1"/><path d="M9 9.5c0-.8.9-1.5 2-1.5s2 .7 2 1.5-2 2-2 2.5 .9 1.5 2 1.5 2-.7 2-1.5"/></svg>
                {%- when 'love' -%}
                  <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="8"/><circle cx="11" cy="11" r="3"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="8"/><line x1="8" y1="8" x2="14" y2="14" stroke-width="1.1"/><line x1="14" y1="8" x2="8" y2="14" stroke-width="1.1"/></svg>
              {%- endcase -%}
            </span>
            <span class="energy-diag__option-text">{{ opt }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    <!-- Column 3: Contact -->
    <div class="energy-diag__col energy-diag__col--contact">
      <div class="energy-diag__step"><span>3</span></div>
      <p class="energy-diag__question">{{ section.settings.q3_label }}</p>
      <input
        type="text"
        id="energy-diag-contact-{{ section.id }}"
        class="energy-diag__input"
        placeholder="{{ section.settings.input_placeholder }}"
        autocomplete="off"
      >
      <button class="energy-diag__submit" data-section="{{ section.id }}" data-whatsapp="{{ section.settings.whatsapp_number }}">
        {{ section.settings.submit_label }}
      </button>
    </div>

  </div><!-- /.energy-diag__grid -->
</div>

<script>
(function(){
  document.querySelectorAll('.energy-diag__option').forEach(function(label){
    label.addEventListener('click', function(){
      var group = label.closest('.energy-diag__options');
      group.querySelectorAll('.energy-diag__option').forEach(function(l){ l.classList.remove('is-selected'); });
      label.classList.add('is-selected');
    });
  });

  document.querySelectorAll('.energy-diag__submit').forEach(function(btn){
    btn.addEventListener('click', function(){
      var sid   = btn.dataset.section;
      var wa    = btn.dataset.whatsapp || '';
      var q1val = document.querySelector('[name="q1-'+sid+'"]:checked');
      var q2val = document.querySelector('[name="q2-'+sid+'"]:checked');
      var contact = document.getElementById('energy-diag-contact-'+sid);
      var contactVal = contact ? contact.value.trim() : '';

      if (!q1val || !q2val) {
        alert('请先完成前两步选择');
        return;
      }
      if (!contactVal) {
        contact && contact.focus();
        return;
      }

      var msg = encodeURIComponent(
        '【AoSharma 能量诊断】\n空间: ' + q1val.value +
        '\n目标: ' + q2val.value +
        '\n联系方式: ' + contactVal
      );

      if (wa) {
        window.open('https://wa.me/' + wa.replace(/\D/g,'') + '?text=' + msg, '_blank');
      } else {
        btn.textContent = '✓ 已提交，我们将尽快联系你';
        btn.disabled = true;
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Energy Diagnosis Quiz",
  "tag": "section",
  "class": "energy-diag-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "2 分钟找出你当下的磁场缺口"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section subtitle",
      "default": "获取专属能量诊断报告"
    },
    {
      "type": "header",
      "content": "Question 1"
    },
    {
      "type": "text",
      "id": "q1_label",
      "label": "Question 1 text",
      "default": "你目前感到最焦虑的空间是？"
    },
    {
      "type": "textarea",
      "id": "q1_options",
      "label": "Options (separated by |)",
      "default": "办公室／职场|卧室／睡眠|家庭关系"
    },
    {
      "type": "textarea",
      "id": "q1_tags",
      "label": "Tags per option (| separated)",
      "default": "career|sleep|family"
    },
    {
      "type": "header",
      "content": "Question 2"
    },
    {
      "type": "text",
      "id": "q2_label",
      "label": "Question 2 text",
      "default": "你在 2025 年最想突破的目标是？"
    },
    {
      "type": "textarea",
      "id": "q2_options",
      "label": "Options (separated by |)",
      "default": "财富倍增|情感正缘|防小人避是非"
    },
    {
      "type": "textarea",
      "id": "q2_tags",
      "label": "Tags per option (| separated)",
      "default": "wealth|love|protection"
    },
    {
      "type": "header",
      "content": "Contact Step"
    },
    {
      "type": "text",
      "id": "q3_label",
      "label": "Contact step label",
      "default": "留下你的联系方式，接收专属诊断报告"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "请输入邮箱或 WhatsApp"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "获取诊断结果"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp number (with country code, e.g. 14155551234)",
      "info": "If blank, shows a confirmation message instead of opening WhatsApp."
    }
  ],
  "presets": [
    {
      "name": "Energy Diagnosis Quiz"
    }
  ]
}
{% endschema %}
