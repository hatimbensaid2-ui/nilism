<section class="hero-banner" aria-label="Hero banner">

  <!-- ── Background layer ── -->
  {%- if section.settings.image != blank -%}
    <img
      class="hero-banner__bg"
      src="{{ section.settings.image | image_url: width: 1800 }}"
      srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1800 }} 1800w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: section.settings.heading }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    <div class="hero-banner__bg hero-banner__bg--cosmic">
      <!-- Star field -->
      <div class="hero-banner__stars hero-banner__stars--sm"></div>
      <div class="hero-banner__stars hero-banner__stars--md"></div>
      <!-- Nebula glows -->
      <div class="hero-banner__nebula hero-banner__nebula--purple"></div>
      <div class="hero-banner__nebula hero-banner__nebula--gold"></div>
    </div>
  {%- endif -%}

  <!-- Dark vignette overlay -->
  <div class="hero-banner__overlay"></div>

  <!-- ── Inner layout: text left | crystal right ── -->
  <div class="hero-banner__layout">

    <!-- LEFT: Text content -->
    <div class="hero-banner__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hero-banner__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero-banner__title">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link | default: '#crystal-quiz' }}"
          class="hero-banner__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <!-- RIGHT: Crystal / feature image -->
    <div class="hero-banner__crystal-wrap">
      {%- if section.settings.crystal_image != blank -%}
        <img
          class="hero-banner__crystal-img"
          src="{{ section.settings.crystal_image | image_url: width: 900 }}"
          srcset="{{ section.settings.crystal_image | image_url: width: 500 }} 500w,
                  {{ section.settings.crystal_image | image_url: width: 900 }} 900w"
          sizes="(max-width: 768px) 80vw, 50vw"
          alt="{{ section.settings.crystal_image.alt | default: 'Crystal' }}"
          loading="eager"
        >
      {%- else -%}
        <!-- Placeholder mandala ring + crystal glow -->
        <div class="hero-banner__crystal-placeholder">
          <div class="hero-banner__mandala-ring"></div>
          <div class="hero-banner__crystal-glow"></div>
          <svg class="hero-banner__crystal-svg" viewBox="0 0 300 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Crystal body -->
            <defs>
              <linearGradient id="crystalGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#FFE082" stop-opacity="0.95"/>
                <stop offset="30%" stop-color="#F4A800" stop-opacity="0.9"/>
                <stop offset="65%" stop-color="#C9963B" stop-opacity="0.85"/>
                <stop offset="100%" stop-color="#8B6020" stop-opacity="0.7"/>
              </linearGradient>
              <linearGradient id="crystalShine" x1="20%" y1="0%" x2="80%" y2="100%">
                <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.6"/>
                <stop offset="50%" stop-color="#FFE082" stop-opacity="0.1"/>
                <stop offset="100%" stop-color="#F4A800" stop-opacity="0.0"/>
              </linearGradient>
              <filter id="glow">
                <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
                <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <!-- Main crystal facets -->
            <polygon points="150,20 210,120 190,360 150,390 110,360 90,120" fill="url(#crystalGrad)" filter="url(#glow)" opacity="0.95"/>
            <!-- Left facet -->
            <polygon points="150,20 90,120 70,200 90,300 110,360 150,390" fill="#C9963B" opacity="0.55"/>
            <!-- Right facet -->
            <polygon points="150,20 210,120 230,200 210,300 190,360 150,390" fill="#FFE082" opacity="0.35"/>
            <!-- Top facet highlight -->
            <polygon points="150,20 210,120 150,130 90,120" fill="#FFFFFF" opacity="0.45"/>
            <!-- Shine overlay -->
            <polygon points="150,20 210,120 190,360 150,390 110,360 90,120" fill="url(#crystalShine)"/>
            <!-- Inner line details -->
            <line x1="150" y1="20" x2="150" y2="390" stroke="#FFE082" stroke-width="0.5" opacity="0.4"/>
            <line x1="90" y1="120" x2="210" y2="120" stroke="#FFE082" stroke-width="0.5" opacity="0.3"/>
            <line x1="100" y1="200" x2="200" y2="200" stroke="#FFE082" stroke-width="0.5" opacity="0.25"/>
            <!-- Sparkle top -->
            <circle cx="150" cy="18" r="4" fill="#FFFFFF" opacity="0.9" filter="url(#glow)"/>
            <line x1="150" y1="4" x2="150" y2="8" stroke="white" stroke-width="1.5" opacity="0.8"/>
            <line x1="136" y1="10" x2="139" y2="13" stroke="white" stroke-width="1.5" opacity="0.6"/>
            <line x1="164" y1="10" x2="161" y2="13" stroke="white" stroke-width="1.5" opacity="0.6"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

  </div><!-- /.hero-banner__layout -->

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Full background image",
      "info": "Optional. Replaces the cosmic gradient. Recommended: 1800×900px"
    },
    {
      "type": "header",
      "content": "Crystal / Feature Image"
    },
    {
      "type": "image_picker",
      "id": "crystal_image",
      "label": "Crystal image (right side)",
      "info": "Upload your crystal illustration. PNG with transparency recommended."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "九紫离火年 · Year of Cosmic Fire"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "九紫离火 聚能转运"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "开启你的专属高频磁场"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "即刻开启测试 (Take the Quiz)"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
