<section
  class="hero-banner{% if section.settings.image != blank %} hero-banner--has-image{% endif %}"
  aria-label="Hero banner"
  style="--hero-height-desktop: {{ section.settings.height_desktop }}vh; --hero-height-mobile: {{ section.settings.height_mobile }}vh; --hero-img-x: {{ section.settings.image_position_x }}%; --hero-img-y: {{ section.settings.image_position_y }}%; --hero-overlay: {{ section.settings.overlay_opacity | times: 0.01 }}; --hero-content-y: {{ section.settings.content_position }};"
>

  {%- if section.settings.image != blank -%}
    <!-- Full image in normal flow — section height follows the image -->
    <img
      class="hero-banner__bg-img"
      src="{{ section.settings.image | image_url: width: 1800 }}"
      srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1800 }} 1800w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: section.settings.heading }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    <!-- Cosmic fallback stays absolutely positioned (no real image) -->
    <div class="hero-banner__bg hero-banner__bg--cosmic">
      <div class="hero-banner__stars hero-banner__stars--sm"></div>
      <div class="hero-banner__stars hero-banner__stars--md"></div>
      <div class="hero-banner__nebula hero-banner__nebula--purple"></div>
      <div class="hero-banner__nebula hero-banner__nebula--gold"></div>
    </div>
  {%- endif -%}

  <!-- Dark vignette overlay -->
  <div class="hero-banner__overlay"></div>

  <!-- ── Text content ── -->
  <div class="hero-banner__content-wrap">

    {%- if section.settings.eyebrow != blank -%}
      <span class="hero-banner__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-banner__title">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#crystal-quiz' }}"
        class="hero-banner__btn"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

  </div><!-- /.hero-banner__content-wrap -->

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop height",
      "default": 56,
      "info": "Height as % of screen. 56 = 16:9 feel, 75 = taller, 100 = full screen."
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Mobile height",
      "default": 60,
      "info": "Height on phones. 60 is a good starting point."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Full background image",
      "info": "Optional. Replaces the cosmic gradient. Recommended: 1800×900px"
    },
    {
      "type": "range",
      "id": "image_position_x",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image horizontal position",
      "default": 50,
      "info": "0 = left edge · 50 = centre · 100 = right edge"
    },
    {
      "type": "range",
      "id": "image_position_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image vertical position",
      "default": 50,
      "info": "0 = top · 50 = centre · 100 = bottom"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 40,
      "info": "Dark veil over the image. 0 = no overlay, 80 = very dark."
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Text vertical position",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center",     "label": "Centre" },
        { "value": "flex-end",   "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "九紫离火年 · Year of Cosmic Fire"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "九紫离火 聚能转运"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "开启你的专属高频磁场"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "即刻开启测试 (Take the Quiz)"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
