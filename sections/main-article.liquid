<article class="article-page">

  <header class="article-page__header container">
    <p class="article-page__breadcrumb">
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      <span aria-hidden="true">·</span>
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: "%B %d, %Y" }}</time>
    </p>
    <h1 class="article-page__title">{{ article.title }}</h1>
    {%- if article.author != blank and section.settings.show_author -%}
      <p class="article-page__author">By {{ article.author }}</p>
    {%- endif -%}
    {%- if article.tags.size > 0 -%}
      <div class="article-page__tags">
        {%- for tag in article.tags -%}
          <span class="article-page__tag">{{ tag }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </header>

  {%- if article.image != blank -%}
    <div class="article-page__hero">
      <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.title | escape }}" loading="eager">
    </div>
  {%- endif -%}

  <div class="article-page__content container rte">
    {{ article.content }}
  </div>

  {%- if section.settings.show_share -%}
    <div class="article-page__share container">
      <p class="article-page__share-label">Share this article</p>
      <div class="article-page__share-links">
        <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Twitter">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 5.92a8.4 8.4 0 01-2.36.65 4.12 4.12 0 001.8-2.27 8.18 8.18 0 01-2.6 1A4.1 4.1 0 0011.85 9.4a11.65 11.65 0 01-8.46-4.29 4.1 4.1 0 001.27 5.48 4.07 4.07 0 01-1.86-.51v.05a4.1 4.1 0 003.29 4.02 4.1 4.1 0 01-1.85.07 4.11 4.11 0 003.83 2.85A8.23 8.23 0 012 18.55 11.62 11.62 0 008.29 20.4c7.55 0 11.68-6.25 11.68-11.68 0-.18 0-.36-.01-.53A8.36 8.36 0 0022 5.92z"/></svg>
        </a>
        <a href="https://www.pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" aria-label="Share on Pinterest">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.76 1.22-5.17 1.22-5.17s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.57 2.25-.87 3.5-.25 1.05.52 1.9 1.55 1.9 1.86 0 3.11-2.37 3.11-5.17 0-2.14-1.44-3.64-3.5-3.64-2.38 0-3.78 1.79-3.78 3.63 0 .72.28 1.49.62 1.91a.25.25 0 01.06.24l-.23.95c-.04.14-.12.18-.28.11-1.04-.48-1.69-2-1.69-3.22 0-2.62 1.9-5.03 5.49-5.03 2.88 0 5.12 2.05 5.12 4.79 0 2.86-1.8 5.16-4.3 5.16-.84 0-1.63-.44-1.9-.95l-.52 1.94c-.19.72-.69 1.62-1.03 2.17.78.24 1.6.37 2.46.37 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
        </a>
      </div>
    </div>
  {%- endif -%}

  {%- if blog.comments_enabled? -%}
    <section class="article-comments container">
      <h2 class="article-comments__heading">{{ article.comments_count }} {% if article.comments_count == 1 %}Comment{% else %}Comments{% endif %}</h2>
      {%- if article.comments_count > 0 -%}
        <ul class="article-comments__list">
          {%- for comment in article.comments -%}
            <li class="article-comment">
              <p class="article-comment__author">{{ comment.author }} · <time>{{ comment.created_at | date: "%B %d, %Y" }}</time></p>
              <div class="article-comment__body">{{ comment.content }}</div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- form 'new_comment', article -%}
        <div class="article-comments__form">
          <h3>Leave a comment</h3>
          {%- if form.errors -%}
            <p class="form-error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <p class="form-success">Thanks! Your comment was posted{% if blog.moderated? %} and is awaiting review{% endif %}.</p>
          {%- endif -%}
          <div class="article-comments__row">
            <input type="text" name="comment[author]" placeholder="Name" required>
            <input type="email" name="comment[email]" placeholder="Email" required>
          </div>
          <textarea name="comment[body]" placeholder="Your message" rows="4" required></textarea>
          <button type="submit" class="btn btn--solid-gold">Post comment</button>
        </div>
      {%- endform -%}
    </section>
  {%- endif -%}

  {%- if blog.next_article or blog.previous_article -%}
    <nav class="article-page__nav container" aria-label="Article navigation">
      {%- if blog.previous_article -%}
        <a href="{{ blog.previous_article }}" class="article-page__nav-link article-page__nav-link--prev">
          <span class="article-page__nav-label">← Previous</span>
        </a>
      {%- endif -%}
      {%- if blog.next_article -%}
        <a href="{{ blog.next_article }}" class="article-page__nav-link article-page__nav-link--next">
          <span class="article-page__nav-label">Next →</span>
        </a>
      {%- endif -%}
    </nav>
  {%- endif -%}

</article>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "class": "article-template-wrap",
  "settings": [
    { "type": "checkbox", "id": "show_author", "label": "Show author",       "default": true },
    { "type": "checkbox", "id": "show_share",  "label": "Show share buttons","default": true }
  ],
  "presets": [{ "name": "Article" }]
}
{% endschema %}
