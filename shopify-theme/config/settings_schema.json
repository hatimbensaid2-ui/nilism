[
  {
    "name": "theme_info",
    "theme_name": "Nilism",
    "theme_version": "1.0.0",
    "theme_author": "Nilism",
    "theme_documentation_url": "https://nilism.com",
    "theme_support_url": "https://nilism.com/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#F5F0EB"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#2C1F10"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Accent colour",
        "default": "#B8936A"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border colour",
        "default": "#D4C4B0"
      },
      {
        "type": "color",
        "id": "color_header_bg",
        "label": "Header background",
        "default": "#FDFAF7"
      },
      {
        "type": "color",
        "id": "color_footer_bg",
        "label": "Footer background",
        "default": "#2C1F10"
      },
      {
        "type": "color",
        "id": "color_button_bg",
        "label": "Button colour",
        "default": "#B8936A"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "cormorant_garamond_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "jost_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "min": 13,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Body font size",
        "default": 16
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 140
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32 x 32px .png recommended"
      }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main menu",
        "default": "main-menu"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "page", "label": "Cart page" },
          { "value": "drawer", "label": "Drawer" }
        ],
        "default": "page"
      }
    ]
  }
]
