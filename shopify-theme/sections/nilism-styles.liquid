{%- comment -%}
  Global style overrides injected into <head> via content_for_header.
  This section has no visible output — it only writes a <style> block.
{%- endcomment -%}

{%- if section.settings.accent_color != blank
    or section.settings.body_font_size != blank
    or section.settings.border_radius != blank -%}
<style>
  :root {
    {%- if section.settings.accent_color != blank -%}
      --gold: {{ section.settings.accent_color }};
    {%- endif -%}
    {%- if section.settings.body_font_size != blank -%}
      font-size: {{ section.settings.body_font_size }}px;
    {%- endif -%}
    {%- if section.settings.border_radius != blank -%}
      --radius-card: {{ section.settings.border_radius }}px;
    {%- endif -%}
  }
  {%- if section.settings.hide_announcement -%}
    .announcement-bar { display: none !important; }
  {%- endif -%}
  {%- if section.settings.custom_css != blank -%}
    {{ section.settings.custom_css }}
  {%- endif -%}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Nilism Styles",
  "tag": null,
  "class": "nilism-styles-global",
  "limit": 1,
  "settings": [
    { "type": "color",   "id": "accent_color",      "label": "Accent / gold color",   "default": "#B8936A" },
    { "type": "range",   "id": "body_font_size",     "label": "Base font size (px)",   "min": 14, "max": 20, "step": 1, "default": 16 },
    { "type": "range",   "id": "border_radius",      "label": "Card border radius (px)","min": 0,  "max": 24, "step": 2, "default": 12 },
    { "type": "checkbox","id": "hide_announcement",  "label": "Hide announcement bar", "default": false },
    { "type": "textarea","id": "custom_css",         "label": "Custom CSS",            "info": "Advanced: inject extra CSS rules here." }
  ]
}
{% endschema %}
