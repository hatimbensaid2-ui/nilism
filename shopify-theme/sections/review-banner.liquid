<section class="review-banner section-{{ section.id }}">

  <!-- Background image -->
  {%- if section.settings.image != blank -%}
    <img
      class="review-banner__bg"
      src="{{ section.settings.image | image_url: width: 1800 }}"
      srcset="{{ section.settings.image | image_url: width: 900 }} 900w,
              {{ section.settings.image | image_url: width: 1400 }} 1400w,
              {{ section.settings.image | image_url: width: 1800 }} 1800w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: section.settings.heading }}"
      loading="lazy"
    >
  {%- else -%}
    <!-- Placeholder: warm stone/crystal hands scene -->
    <div class="review-banner__bg" style="
      background: linear-gradient(120deg,
        #EDE4D8 0%, #E0D4C4 20%, #D8CCBA 40%,
        #CEC0AA 60%, #C4B49A 80%, #B8A888 100%
      );
    ">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 75% 60%,rgba(255,255,255,0.25) 0%,transparent 65%);"></div>
    </div>
  {%- endif -%}

  <!-- Gradient overlay: cream on left fading right so image shows through -->
  <div class="review-banner__overlay"></div>

  <!-- Text content -->
  <div class="review-banner__content">

    {%- if section.settings.show_stars -%}
      <div class="review-banner__stars" aria-label="5 stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
            <polygon points="8,1.5 10,6 15,6.4 11.5,9.6 12.6,14.5 8,11.8 3.4,14.5 4.5,9.6 1,6.4 6,6" fill="currentColor"/>
          </svg>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="review-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.quote != blank -%}
      <blockquote class="review-banner__quote">
        <span class="review-banner__open-quote" aria-hidden="true">&ldquo;&rdquo;</span>
        <p>{{ section.settings.quote }}</p>
      </blockquote>
    {%- endif -%}

    {%- if section.settings.author != blank -%}
      <cite class="review-banner__author">— {{ section.settings.author }}</cite>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Review Banner",
  "tag": "section",
  "class": "review-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Best with hands/crystals photo. Recommended 1800×560px, subject on the right side."
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show stars",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made with Love & Master Cleansed"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Review quote",
      "default": "I ordered a rose quartz bracelet to attract love and find my soulmate. The piece is exquisite and I could tell it was prepared with care. I wear it every day and honestly feel more positive and open for new connections."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Reviewer name",
      "default": "Emily L."
    }
  ],
  "presets": [
    {
      "name": "Review Banner"
    }
  ]
}
{% endschema %}
