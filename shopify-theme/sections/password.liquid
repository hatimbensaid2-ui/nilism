<div class="password-page">
  <div class="password-page__inner">
    <div class="password-page__logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="max-width:180px;">
      {%- else -%}
        <p class="site-header__logo-text">{{ shop.name }}</p>
      {%- endif -%}
    </div>

    <div class="password-page__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="password-page__title">{{ section.settings.heading }}</h1>
      {%- if section.settings.subtext != blank -%}
        <p class="password-page__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.show_email_form -%}
        <div class="password-page__notify">
          <p class="password-page__notify-label">{{ section.settings.notify_label }}</p>
          {%- form 'customer', id: 'password-notify-form' -%}
            <input type="hidden" name="contact[tags]" value="prospect, password-page-notify">
            <div class="password-page__form-row">
              <input
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.email_placeholder }}"
                required
                class="password-page__input"
              >
              <button type="submit" class="btn btn--solid-gold">{{ section.settings.email_btn }}</button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="password-page__success">✓ {{ section.settings.success_msg }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      <div class="password-page__unlock">
        <details>
          <summary class="password-page__unlock-toggle">{{ section.settings.enter_label }}</summary>
          {%- form 'storefront_password' -%}
            <div class="password-page__form-row" style="margin-top:16px;">
              <input
                type="password"
                name="password"
                placeholder="{{ section.settings.password_placeholder }}"
                class="password-page__input"
                required
              >
              <button type="submit" class="btn btn--outline-gold">{{ section.settings.unlock_label }}</button>
            </div>
            {%- if form.errors -%}
              <p class="password-page__error">{{ 'general.password_page.login_form_error' | t }}</p>
            {%- endif -%}
          {%- endform -%}
        </details>
      </div>
    </div>

    {%- if section.settings.show_social -%}
      <div class="password-page__social">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "password-wrap",
  "settings": [
    { "type": "image_picker", "id": "logo",   "label": "Logo image" },
    { "type": "text",    "id": "eyebrow",  "label": "Eyebrow",  "default": "Coming Soon" },
    { "type": "text",    "id": "heading",  "label": "Heading",  "default": "Something Beautiful Is Coming" },
    { "type": "textarea","id": "subtext",  "label": "Subtext",  "default": "We're preparing something extraordinary. Be the first to know when we launch." },
    { "type": "header",  "id": "notify_header", "content": "Email notification form" },
    { "type": "checkbox","id": "show_email_form",  "label": "Show email form", "default": true },
    { "type": "text",    "id": "notify_label",    "label": "Notify label",     "default": "Get notified when we launch:" },
    { "type": "text",    "id": "email_placeholder","label": "Email placeholder","default": "Your email address" },
    { "type": "text",    "id": "email_btn",        "label": "Subscribe button", "default": "Notify Me" },
    { "type": "text",    "id": "success_msg",      "label": "Success message",  "default": "You're on the list! We'll notify you at launch." },
    { "type": "header",  "id": "access_header", "content": "Password access" },
    { "type": "text",    "id": "enter_label",        "label": "Enter password label",  "default": "Enter store password →" },
    { "type": "text",    "id": "password_placeholder","label": "Password placeholder", "default": "Password" },
    { "type": "text",    "id": "unlock_label",        "label": "Unlock button",        "default": "Enter" },
    { "type": "header",  "id": "social_header", "content": "Social" },
    { "type": "checkbox","id": "show_social", "label": "Show social icons", "default": true }
  ]
}
{% endschema %}
