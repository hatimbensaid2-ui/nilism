<section class="testimonial-banner section-{{ section.id }}">

  {%- if section.settings.image != blank -%}
    <img
      class="testimonial-banner__bg"
      src="{{ section.settings.image | image_url: width: 1800 }}"
      srcset="{{ section.settings.image | image_url: width: 900 }} 900w,
              {{ section.settings.image | image_url: width: 1800 }} 1800w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: 'Crystal testimonial' }}"
      loading="lazy"
    >
  {%- else -%}
    <div class="testimonial-banner__bg" style="
      background: linear-gradient(135deg, #E8DDD0 0%, #D8CCB8 25%, #E0D4C4 50%, #C8BCB0 75%, #D4C8BC 100%);
    ">
      <div style="position:absolute;inset:0;background:radial-gradient(circle 120px at 30% 50%,rgba(255,255,255,0.3) 0%,transparent 70%),radial-gradient(circle 80px at 70% 40%,rgba(255,255,255,0.25) 0%,transparent 70%);"></div>
    </div>
  {%- endif -%}

  <div class="testimonial-banner__overlay"></div>

  <div class="testimonial-banner__content">

    {%- if section.settings.show_stars -%}
      <div class="testimonial-banner__stars" aria-label="{{ section.settings.rating }} out of 5 stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 14 14" width="20" height="20"><polygon points="7,1 8.8,5 13,5.5 10,8.4 10.9,12.5 7,10.5 3.1,12.5 4,8.4 1,5.5 5.2,5" fill="currentColor"/></svg>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="testimonial-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.quote_text != blank -%}
      <blockquote class="testimonial-banner__quote">
        <span class="testimonial-banner__quote-mark" aria-hidden="true">&ldquo;&rdquo;</span>
        <p>{{ section.settings.quote_text }}</p>
      </blockquote>
    {%- endif -%}

    {%- if section.settings.author != blank -%}
      <cite class="testimonial-banner__author">— {{ section.settings.author }}</cite>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Testimonial Banner",
  "tag": "section",
  "class": "testimonial-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: 1800×700px — hands/crystals photo works great"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating (for accessibility)",
      "default": "5"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made with Love & Master Cleansed"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote / review text",
      "default": "I ordered a rose quartz bracelet to attract love and find my soulmate. The piece is exquisite and I could tell it was prepared with care. I wear it every day and honestly feel more positive and open for new connections."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author name",
      "default": "Emily L."
    }
  ],
  "presets": [
    {
      "name": "Testimonial Banner"
    }
  ]
}
{% endschema %}
