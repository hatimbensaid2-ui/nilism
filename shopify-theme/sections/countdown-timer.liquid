{%- assign end_date = section.settings.end_date -%}

<section class="countdown-section section-{{ section.id }}"
  style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <div class="container">
    <div class="countdown-section__inner">

      <div class="countdown-section__text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="countdown-section__eyebrow" style="color:{{ section.settings.accent_color }};">
            {{ section.settings.eyebrow }}
          </span>
        {%- endif -%}
        <h2 class="countdown-section__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtext != blank -%}
          <p class="countdown-section__sub">{{ section.settings.subtext }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--solid-gold" style="margin-top:24px;">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="countdown-section__timer">
        <div class="countdown-timer" data-end="{{ section.settings.end_date }}" id="timer-{{ section.id }}">
          <div class="countdown-digit-wrap">
            <span class="countdown-digit" id="days-{{ section.id }}">00</span>
            <span class="countdown-label">Days</span>
          </div>
          <span class="countdown-sep" aria-hidden="true">:</span>
          <div class="countdown-digit-wrap">
            <span class="countdown-digit" id="hours-{{ section.id }}">00</span>
            <span class="countdown-label">Hours</span>
          </div>
          <span class="countdown-sep" aria-hidden="true">:</span>
          <div class="countdown-digit-wrap">
            <span class="countdown-digit" id="mins-{{ section.id }}">00</span>
            <span class="countdown-label">Minutes</span>
          </div>
          <span class="countdown-sep" aria-hidden="true">:</span>
          <div class="countdown-digit-wrap">
            <span class="countdown-digit" id="secs-{{ section.id }}">00</span>
            <span class="countdown-label">Seconds</span>
          </div>
        </div>
        {%- if section.settings.offer_text != blank -%}
          <p class="countdown-section__offer" style="color:{{ section.settings.accent_color }};">
            {{ section.settings.offer_text }}
          </p>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var endDate = new Date("{{ section.settings.end_date }}").getTime();
  if (isNaN(endDate)) return;
  function pad(n) { return n < 10 ? '0' + n : n; }
  function tick() {
    var now  = new Date().getTime();
    var diff = endDate - now;
    if (diff <= 0) {
      ['days','hours','mins','secs'].forEach(function(u){
        var el = document.getElementById(u + '-{{ section.id }}');
        if (el) el.textContent = '00';
      });
      return;
    }
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000)  / 60000);
    var s = Math.floor((diff % 60000)    / 1000);
    var dEl = document.getElementById('days-{{ section.id }}');
    var hEl = document.getElementById('hours-{{ section.id }}');
    var mEl = document.getElementById('mins-{{ section.id }}');
    var sEl = document.getElementById('secs-{{ section.id }}');
    if (dEl) dEl.textContent = pad(d);
    if (hEl) hEl.textContent = pad(h);
    if (mEl) mEl.textContent = pad(m);
    if (sEl) sEl.textContent = pad(s);
  }
  tick();
  setInterval(tick, 1000);
})();
</script>

{% schema %}
{
  "name": "Countdown Timer",
  "tag": "section",
  "class": "countdown-section-wrap",
  "settings": [
    { "type": "text",  "id": "eyebrow",      "label": "Eyebrow",       "default": "⚡ Flash Sale" },
    { "type": "text",  "id": "heading",      "label": "Heading",       "default": "Sale Ends In" },
    { "type": "text",  "id": "subtext",      "label": "Sub-text",      "default": "20% off sitewide — use code ENERGY20 at checkout" },
    { "type": "text",  "id": "offer_text",   "label": "Offer label",   "default": "Use code ENERGY20" },
    { "type": "text",  "id": "end_date",     "label": "End date/time (ISO 8601)", "default": "2026-12-31T23:59:59" },
    { "type": "text",  "id": "button_label", "label": "Button label",  "default": "Shop the Sale" },
    { "type": "url",   "id": "button_link",  "label": "Button link",   "default": "/collections/all" },
    { "type": "color", "id": "bg_color",     "label": "Background",    "default": "#2A1E12" },
    { "type": "color", "id": "text_color",   "label": "Text color",    "default": "#F5F0EB" },
    { "type": "color", "id": "accent_color", "label": "Accent / timer color", "default": "#B8936A" }
  ],
  "presets": [{ "name": "Countdown Timer" }]
}
{% endschema %}
