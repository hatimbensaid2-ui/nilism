<section class="collection-tabs-section section-{{ section.id }}"
  style="{% if section.settings.bg_white %}background:var(--white);{% endif %}">
  <div class="container">

    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
    </div>

    <!-- Tab nav -->
    <div class="ctabs__nav" role="tablist">
      {%- for block in section.blocks -%}
        <button
          class="ctab-btn{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-controls="ctab-panel-{{ section.id }}-{{ forloop.index }}"
          data-tab="{{ section.id }}-{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.icon != blank -%}
            <span class="ctab-btn__icon">{{ block.settings.icon }}</span>
          {%- endif -%}
          {{ block.settings.label }}
        </button>
      {%- endfor -%}
    </div>

    <!-- Tab panels -->
    {%- for block in section.blocks -%}
      {%- assign tab_collection = collections[block.settings.collection] -%}
      <div
        class="ctab-panel{% if forloop.first %} is-active{% endif %}"
        id="ctab-panel-{{ section.id }}-{{ forloop.index }}"
        role="tabpanel"
      >
        <div class="product-grid">
          {%- if tab_collection != blank -%}
            {%- for product in tab_collection.products limit: section.settings.products_to_show -%}
              {%- render 'product-card', product: product -%}
            {%- else -%}
              {%- for i in (1..section.settings.products_to_show) -%}
                {%- render 'product-card-placeholder', index: i -%}
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..section.settings.products_to_show) -%}
              {%- render 'product-card-placeholder', index: i -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
        {%- if block.settings.view_all_label != blank -%}
          <div style="text-align:center;margin-top:40px;">
            <a href="{{ tab_collection.url | default: '/collections/all' }}" class="btn btn--outline-gold">
              {{ block.settings.view_all_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}

  </div>
</section>

<script>
document.querySelectorAll('.ctab-btn').forEach(function (btn) {
  btn.addEventListener('click', function () {
    var tabId = this.dataset.tab;
    var wrap  = this.closest('.collection-tabs-section');
    wrap.querySelectorAll('.ctab-btn').forEach(function (b) {
      b.classList.remove('is-active');
      b.setAttribute('aria-selected', 'false');
    });
    wrap.querySelectorAll('.ctab-panel').forEach(function (p) { p.classList.remove('is-active'); });
    this.classList.add('is-active');
    this.setAttribute('aria-selected', 'true');
    var panel = document.getElementById('ctab-panel-' + tabId);
    if (panel) panel.classList.add('is-active');
  });
});
</script>

{% schema %}
{
  "name": "Collection Tabs",
  "tag": "section",
  "class": "collection-tabs-wrap",
  "settings": [
    { "type": "text",    "id": "eyebrow",          "label": "Eyebrow",              "default": "Shop by Intention" },
    { "type": "text",    "id": "heading",           "label": "Heading",              "default": "Explore Collections" },
    { "type": "range",   "id": "products_to_show",  "label": "Products per tab",     "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "checkbox","id": "bg_white",          "label": "White background",     "default": false }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        { "type": "text",       "id": "label",          "label": "Tab label",     "default": "Wealth" },
        { "type": "text",       "id": "icon",           "label": "Tab icon (emoji or symbol)", "default": "✦" },
        { "type": "collection", "id": "collection",     "label": "Collection" },
        { "type": "text",       "id": "view_all_label", "label": "View All label","default": "View All" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Tabs",
      "blocks": [
        { "type": "tab", "settings": { "label": "Wealth",     "icon": "✦", "view_all_label": "View Wealth Collection" } },
        { "type": "tab", "settings": { "label": "Love",       "icon": "♡", "view_all_label": "View Love Collection"   } },
        { "type": "tab", "settings": { "label": "Protection", "icon": "◈", "view_all_label": "View All Protection"    } },
        { "type": "tab", "settings": { "label": "New",        "icon": "◉", "view_all_label": "View New Arrivals"      } }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
