<section class="page-content-section">
  <div class="container">
    <header class="page-content__header">
      {%- if section.settings.show_eyebrow and section.settings.eyebrow != blank -%}
        <span class="rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="page-content__title">{{ page.title }}</h1>
      {%- if section.settings.show_subtitle and section.settings.subtitle != blank -%}
        <p class="page-content__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>
    <div class="page-content__body rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page content",
  "tag": "section",
  "class": "page-content-wrap",
  "settings": [
    { "type": "checkbox", "id": "show_eyebrow",  "label": "Show eyebrow",  "default": true },
    { "type": "text",     "id": "eyebrow",       "label": "Eyebrow text",  "default": "AoSharma" },
    { "type": "checkbox", "id": "show_subtitle", "label": "Show subtitle", "default": false },
    { "type": "text",     "id": "subtitle",      "label": "Subtitle" }
  ],
  "presets": [{ "name": "Page content" }]
}
{% endschema %}
