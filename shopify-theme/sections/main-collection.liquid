{%- assign current_sort  = collection.sort_by | default: collection.default_sort_by -%}
{%- assign total_count  = collection.all_products_count -%}
{%- assign page_count   = collection.products_count -%}

<!-- Collection Banner -->
<div class="collection-hero" style="min-height:{{ section.settings.banner_height }}px;">
  {%- assign banner_img = section.settings.banner_image | default: collection.image -%}
  {%- if banner_img != blank -%}
    <img
      class="collection-hero__bg"
      src="{{ banner_img | image_url: width: 1400 }}"
      srcset="{{ banner_img | image_url: width: 800 }} 800w, {{ banner_img | image_url: width: 1400 }} 1400w"
      sizes="100vw"
      alt="{{ banner_img.alt | default: collection.title }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    <div class="collection-hero__bg" style="background: linear-gradient(160deg, #C8D4E0 0%, #B8C8D8 20%, #D0C4B4 45%, #C4B4A4 65%, #B8C8D4 100%);"></div>
  {%- endif -%}
  <div class="collection-hero__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="collection-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="collection-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- else -%}
      <span class="collection-hero__eyebrow">Collection</span>
    {%- endif -%}
    <h1 class="collection-hero__title">{{ section.settings.banner_title | default: collection.title }}</h1>
    {%- assign desc = section.settings.banner_description | default: collection.description -%}
    {%- if desc != blank -%}
      <p class="collection-hero__desc">{{ desc | strip_html | truncate: 200 }}</p>
    {%- endif -%}
  </div>
</div>


<!-- Product grid -->
<div class="collection-grid-wrap">
  {%- if collection.products.size > 0 -%}
    <div class="collection-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    </div>

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="pagination__btn" aria-label="Previous page">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </a>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="pagination__btn">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}
            <span class="pagination__btn is-current" aria-current="page">{{ part.title }}</span>
          {%- else -%}
            <span class="pagination__btn" style="border:none;cursor:default;">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="pagination__btn" aria-label="Next page">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        {%- endif -%}
      </nav>
    {%- endif -%}

  {%- else -%}
    <div style="text-align:center; padding: 80px 0;">
      <p style="font-family:var(--font-serif);font-size:1.2rem;color:var(--brown-light);margin-bottom:24px;">
        No products found in this collection.
      </p>
      <a href="/collections/all" class="btn btn--outline-gold">Browse All</a>
    </div>
  {%- endif -%}
</div>

<script>
// Filter button visual toggle
document.querySelectorAll('.filter-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    this.classList.toggle('is-active');
  });
});

// Quick add in collection
document.querySelectorAll('.product-card__quick-add').forEach(function(btn) {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    var id = this.dataset.productId;
    if (!id) return;
    var orig = this.textContent;
    this.textContent = 'Adding...';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: id, quantity: 1 })
    }).then(function() {
      btn.textContent = 'Added ✓';
      setTimeout(function() { btn.textContent = orig; }, 2000);
      fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
        var c = document.querySelector('.cart-count');
        if (c) { c.textContent = cart.item_count; c.style.display = 'flex'; }
      });
    }).catch(function() { btn.textContent = orig; });
  });
});
</script>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "main-collection-section",
  "settings": [
    { "type": "header", "content": "Banner" },
    { "type": "image_picker", "id": "banner_image", "label": "Banner image", "info": "Overrides the collection image. Leave blank to use collection image." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Collection" },
    { "type": "text", "id": "banner_title", "label": "Title override", "info": "Leave blank to use collection title" },
    { "type": "textarea", "id": "banner_description", "label": "Description override", "info": "Leave blank to use collection description" },
    { "type": "range", "id": "banner_height", "label": "Banner height (px)", "min": 180, "max": 600, "step": 20, "default": 340, "unit": "px" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darkness (%)", "min": 0, "max": 80, "step": 5, "default": 40, "unit": "%" },
    { "type": "header", "content": "Products grid" },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
  ]
}
{% endschema %}
