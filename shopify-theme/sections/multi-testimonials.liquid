<section class="multi-testimonials section-{{ section.id }}">
  <div class="container">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rich-text__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.rating_summary != blank -%}
        <div class="testimonials-rating-summary">
          <div class="product-stars__icons">
            {%- for i in (1..5) -%}
              <span class="product-stars__icon"><svg viewBox="0 0 14 14"><polygon points="7,1 8.8,5 13,5.5 10,8.4 10.9,12.5 7,10.5 3.1,12.5 4,8.4 1,5.5 5.2,5"/></svg></span>
            {%- endfor -%}
          </div>
          <span class="testimonials-rating-text">{{ section.settings.rating_summary }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.layout == 'carousel' -%}
      <div class="testimonials-carousel-wrap">
        <div class="testimonials-carousel" id="tcarousel-{{ section.id }}">
          {%- for block in section.blocks -%}
            <div class="testimonial-card" {{ block.shopify_attributes }}>
              <div class="testimonial-card__stars">
                {%- assign stars = block.settings.rating | plus: 0 -%}
                {%- for i in (1..5) -%}
                  <span class="product-card__star{% if i > stars %} product-card__star--empty{% endif %}">
                    <svg viewBox="0 0 14 14"><polygon points="7,1 8.8,5 13,5.5 10,8.4 10.9,12.5 7,10.5 3.1,12.5 4,8.4 1,5.5 5.2,5"/></svg>
                  </span>
                {%- endfor -%}
              </div>
              {%- if block.settings.title != blank -%}
                <p class="testimonial-card__title">&ldquo;{{ block.settings.title }}&rdquo;</p>
              {%- endif -%}
              <p class="testimonial-card__body">{{ block.settings.body }}</p>
              <div class="testimonial-card__footer">
                {%- if block.settings.avatar != blank -%}
                  <img src="{{ block.settings.avatar | image_url: width: 60 }}" alt="{{ block.settings.name }}" class="testimonial-card__avatar">
                {%- else -%}
                  <div class="testimonial-card__avatar-placeholder">
                    {{ block.settings.name | slice: 0 }}
                  </div>
                {%- endif -%}
                <div>
                  <p class="testimonial-card__name">{{ block.settings.name }}</p>
                  {%- if block.settings.location != blank -%}
                    <p class="testimonial-card__location">{{ block.settings.location }}</p>
                  {%- endif -%}
                  {%- if block.settings.verified -%}
                    <span class="testimonial-card__verified">✓ Verified Buyer</span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div class="carousel-controls">
          <button class="carousel-btn carousel-btn--prev" aria-label="Previous" onclick="carouselMove('tcarousel-{{ section.id }}', -1)">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="carousel-dots" id="cdots-{{ section.id }}"></div>
          <button class="carousel-btn carousel-btn--next" aria-label="Next" onclick="carouselMove('tcarousel-{{ section.id }}', 1)">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

    {%- else -%}
      <div class="testimonials-grid testimonials-grid--{{ section.settings.columns }}">
        {%- for block in section.blocks -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__stars">
              {%- assign stars = block.settings.rating | plus: 0 -%}
              {%- for i in (1..5) -%}
                <span class="product-card__star{% if i > stars %} product-card__star--empty{% endif %}">
                  <svg viewBox="0 0 14 14"><polygon points="7,1 8.8,5 13,5.5 10,8.4 10.9,12.5 7,10.5 3.1,12.5 4,8.4 1,5.5 5.2,5"/></svg>
                </span>
              {%- endfor -%}
            </div>
            {%- if block.settings.title != blank -%}
              <p class="testimonial-card__title">&ldquo;{{ block.settings.title }}&rdquo;</p>
            {%- endif -%}
            <p class="testimonial-card__body">{{ block.settings.body }}</p>
            <div class="testimonial-card__footer">
              {%- if block.settings.avatar != blank -%}
                <img src="{{ block.settings.avatar | image_url: width: 60 }}" alt="{{ block.settings.name }}" class="testimonial-card__avatar">
              {%- else -%}
                <div class="testimonial-card__avatar-placeholder">{{ block.settings.name | slice: 0 }}</div>
              {%- endif -%}
              <div>
                <p class="testimonial-card__name">{{ block.settings.name }}</p>
                {%- if block.settings.location != blank -%}
                  <p class="testimonial-card__location">{{ block.settings.location }}</p>
                {%- endif -%}
                {%- if block.settings.verified -%}
                  <span class="testimonial-card__verified">✓ Verified Buyer</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "multi-testimonials-section",
  "settings": [
    { "type": "text", "id": "eyebrow",        "label": "Eyebrow",         "default": "Real Results" },
    { "type": "text", "id": "heading",        "label": "Heading",         "default": "What Our Community Says" },
    { "type": "text", "id": "rating_summary", "label": "Rating summary",  "default": "4.9 out of 5 · Based on 1,200+ reviews" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "grid",     "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "select", "id": "columns", "label": "Columns (grid only)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range",      "id": "rating",   "min": 1, "max": 5, "step": 1, "default": 5, "label": "Star rating" },
        { "type": "text",       "id": "title",    "label": "Review headline",    "default": "Life-changing bracelet" },
        { "type": "textarea",   "id": "body",     "label": "Review body",        "default": "I've been wearing my Tiger Eye bracelet for 3 weeks and I already got a promotion at work. The energy is real!" },
        { "type": "image_picker","id": "avatar",  "label": "Avatar photo" },
        { "type": "text",       "id": "name",     "label": "Reviewer name",      "default": "Sarah M." },
        { "type": "text",       "id": "location", "label": "Location / Product", "default": "Los Angeles, CA" },
        { "type": "checkbox",   "id": "verified", "label": "Verified buyer",     "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "title": "I got a promotion!", "body": "I wore my Tiger Eye for 3 weeks and I already got a promotion. The energy shift was immediate — I felt more confident in every meeting.", "name": "Sarah M.", "location": "Los Angeles, CA", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "title": "Found my soulmate", "body": "I ordered Rose Quartz to attract love. Two months later I met my partner at a crystal fair. I 100% believe in the power of these bracelets.", "name": "Emily L.", "location": "New York, NY", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "title": "My anxiety is gone", "body": "The Amethyst bracelet has completely changed my sleep. I wake up calm and centered. I've bought 4 more as gifts for my family.", "name": "Jessica K.", "location": "Toronto, Canada", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "title": "Beautiful quality", "body": "The craftsmanship is incredible. Each bead is perfectly matched and the gold accent is stunning. Worth every penny — I get compliments every day.", "name": "Michelle T.", "location": "Miami, FL", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "title": "Finally feeling protected", "body": "Since wearing my Obsidian bracelet I notice negative people fading from my life. The energy protection is strong and I feel safer everywhere I go.", "name": "Rachel S.", "location": "Chicago, IL", "verified": true } },
        { "type": "review", "settings": { "rating": 5, "title": "A true ritual experience", "body": "The packaging, the ritual card, the blessing — everything feels sacred. This isn't just jewelry, it's an energetic tool. AoSharma stands apart from everything else.", "name": "Mia C.", "location": "Seattle, WA", "verified": true } }
