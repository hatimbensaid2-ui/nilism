{% assign product = product %}

<div class="product-page container" style="padding: 60px 24px; max-width: 1280px; margin: 0 auto;">
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start;">

    <!-- Images -->
    <div>
      <div style="aspect-ratio: 1; overflow: hidden; background: var(--cream); margin-bottom: 16px;">
        {%- if product.featured_image -%}
          <img
            id="product-featured-image"
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | escape }}"
            style="width: 100%; height: 100%; object-fit: cover;"
            loading="eager"
          >
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
          {%- for image in product.images limit: 4 -%}
            <div style="aspect-ratio: 1; overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s;"
                 onclick="document.getElementById('product-featured-image').src='{{ image | image_url: width: 800 }}'">
              <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt }}" style="width:100%;height:100%;object-fit:cover;">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Details -->
    <div>
      <p style="font-size: 0.75rem; color: var(--gold); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;">
        {{ product.type }}
      </p>
      <h1 style="font-family: var(--font-serif); font-size: 2rem; font-weight: 400; color: var(--brown); margin-bottom: 16px; line-height: 1.3;">
        {{ product.title }}
      </h1>
      <p style="font-size: 1.3rem; color: var(--gold-dark); margin-bottom: 28px; letter-spacing: 0.04em;">
        {{ product.price | money }}
        {%- if product.compare_at_price > product.price -%}
          <span style="font-size: 0.9rem; color: var(--brown-light); text-decoration: line-through; margin-left: 10px;">
            {{ product.compare_at_price | money }}
          </span>
        {%- endif -%}
      </p>

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div style="margin-bottom: 20px;">
            <label style="font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brown-mid); display: block; margin-bottom: 8px;">
              {{ option.name }}
            </label>
            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
              {%- for value in option.values -%}
                <button style="padding: 8px 18px; border: 1px solid var(--border); background: transparent; font-family: var(--font-sans); font-size: 0.8rem; cursor: pointer; transition: all 0.2s;"
                        onmouseover="this.style.borderColor='var(--gold)'"
                        onmouseout="this.style.borderColor='var(--border)'">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <form action="/cart/add" method="post" enctype="multipart/form-data" style="margin-bottom: 24px;">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <div style="display: flex; gap: 12px; align-items: center;">
          <div style="display: flex; align-items: center; border: 1px solid var(--border);">
            <button type="button" style="padding: 12px 16px; background: none; border: none; font-size: 1.1rem; cursor: pointer; color: var(--brown);" onclick="var i=this.nextElementSibling; i.value=Math.max(1,+i.value-1)">−</button>
            <input type="number" name="quantity" value="1" min="1" style="width: 48px; text-align: center; border: none; outline: none; font-family: var(--font-sans); font-size: 0.9rem;">
            <button type="button" style="padding: 12px 16px; background: none; border: none; font-size: 1.1rem; cursor: pointer; color: var(--brown);" onclick="var i=this.previousElementSibling; i.value=+i.value+1">+</button>
          </div>
          {%- if product.available -%}
            <button type="submit" class="btn btn--solid-gold" style="flex: 1; padding: 14px 28px; font-size: 0.8rem;">
              Add to Cart
            </button>
          {%- else -%}
            <button type="button" disabled style="flex: 1; padding: 14px 28px; background: var(--border); border: none; color: var(--brown-light); font-family: var(--font-sans); font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;">
              Sold Out
            </button>
          {%- endif -%}
        </div>
      </form>

      {%- if product.description != blank -%}
        <div style="border-top: 1px solid var(--border); padding-top: 24px; font-size: 0.88rem; line-height: 1.75; color: var(--brown-mid);">
          {{ product.description }}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>
