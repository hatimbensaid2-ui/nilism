<div class="container" style="padding: 64px 24px; max-width: 960px; margin: 0 auto; min-height: 60vh;">
  <h1 style="font-family: var(--font-serif); font-size: 2rem; font-weight: 400; margin-bottom: 40px; color: var(--brown); letter-spacing: 0.08em;">Your Cart</h1>

  {%- if cart.item_count == 0 -%}
    <div style="text-align: center; padding: 80px 0;">
      <p style="color: var(--brown-light); font-size: 0.9rem; margin-bottom: 24px;">Your cart is empty.</p>
      <a href="/collections/all" class="btn btn--outline-gold">Continue Shopping</a>
    </div>
  {%- else -%}
    <form action="/cart" method="post">
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="border-bottom: 1px solid var(--border);">
            <th style="text-align: left; padding: 12px 0; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brown-light); font-weight: 400;">Product</th>
            <th style="text-align: center; padding: 12px; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brown-light); font-weight: 400;">Qty</th>
            <th style="text-align: right; padding: 12px 0; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brown-light); font-weight: 400;">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 20px 0; display: flex; gap: 16px; align-items: center;">
                <a href="{{ item.url }}">
                  <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title }}" style="width: 80px; height: 80px; object-fit: cover; background: var(--cream);">
                </a>
                <div>
                  <a href="{{ item.url }}" style="font-family: var(--font-serif); font-size: 1rem; color: var(--brown);">{{ item.product.title }}</a>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p style="font-size: 0.75rem; color: var(--brown-light); margin-top: 4px;">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p style="font-size: 0.8rem; color: var(--gold-dark); margin-top: 4px;">{{ item.price | money }}</p>
                </div>
              </td>
              <td style="text-align: center; padding: 20px 12px;">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-line="{{ forloop.index }}"
                  style="width: 56px; text-align: center; padding: 8px; border: 1px solid var(--border); font-family: var(--font-sans); font-size: 0.85rem;">
              </td>
              <td style="text-align: right; padding: 20px 0; font-size: 0.9rem; color: var(--brown);">
                {{ item.line_price | money }}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div style="margin-top: 32px; display: flex; justify-content: flex-end;">
        <div style="min-width: 280px;">
          <div style="display: flex; justify-content: space-between; padding: 12px 0; border-top: 1px solid var(--border); font-family: var(--font-serif); font-size: 1.1rem;">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p style="font-size: 0.72rem; color: var(--brown-light); margin-bottom: 20px; text-align: right;">Taxes and shipping calculated at checkout.</p>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            <button type="submit" name="update" class="btn btn--outline-gold" style="width: 100%;">Update Cart</button>
            <a href="/checkout" class="btn btn--solid-gold" style="width: 100%; text-align: center;">Check Out</a>
          </div>
        </div>
      </div>
    </form>
  {%- endif -%}
</div>
