<section class="shop-by-intention section-padding">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="intention-grid">
      {%- for block in section.blocks -%}
        <div class="intention-card" {{ block.shopify_attributes }}>
          <div class="intention-card__image-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="intention-card__img"
                loading="lazy"
                width="600"
                height="500"
              >
            {%- else -%}
              <div class="intention-card__placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'intention-card__placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <div class="intention-card__body">
            {%- if block.settings.icon != blank -%}
              <div class="intention-card__icon">
                <img src="{{ block.settings.icon | image_url: width: 60 }}" alt="" width="40" height="40" loading="lazy">
              </div>
            {%- else -%}
              <div class="intention-card__icon intention-card__icon--default">
                {%- case block.settings.icon_type -%}
                  {%- when 'wealth' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 48 48" fill="none">
                      <path d="M24 4C13 4 4 13 4 24s9 20 20 20 20-9 20-20S35 4 24 4z" stroke="#B8860B" stroke-width="1.5" fill="none"/>
                      <path d="M16 28c1.5 2.5 4.5 4 8 4s6.5-1.5 8-4M16 20c1.5-2.5 4.5-4 8-4s6.5 1.5 8 4" stroke="#B8860B" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                      <path d="M20 14c-1 2-1.5 5-1.5 10s.5 8 1.5 10M28 14c1 2 1.5 5 1.5 10s-.5 8-1.5 10" stroke="#B8860B" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                    </svg>
                  {%- when 'love' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 48 48" fill="#C4714A">
                      <path d="M24 40S8 28 8 18a8 8 0 0 1 16-1.6A8 8 0 0 1 40 18c0 10-16 22-16 22z"/>
                    </svg>
                  {%- when 'protection' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 48 48" fill="none">
                      <path d="M24 6L8 12v12c0 9 6.5 17.4 16 20 9.5-2.6 16-11 16-20V12L24 6z" stroke="#5A5A7A" stroke-width="1.5" fill="#5A5A7A" fill-opacity="0.15"/>
                    </svg>
                  {%- else -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 48 48" fill="none">
                      <circle cx="24" cy="24" r="18" stroke="#B8860B" stroke-width="1.5"/>
                    </svg>
                {%- endcase -%}
              </div>
            {%- endif -%}

            {%- if block.settings.title_chinese != blank -%}
              <h3 class="intention-card__title-cn">{{ block.settings.title_chinese }}</h3>
            {%- endif -%}
            {%- if block.settings.subtitle_chinese != blank -%}
              <p class="intention-card__subtitle-cn">{{ block.settings.subtitle_chinese }}</p>
            {%- endif -%}
            {%- if block.settings.title_english != blank -%}
              <p class="intention-card__title-en">{{ block.settings.title_english }}</p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_url }}" class="intention-card__btn">
                {{ block.settings.button_label }}
                <span class="intention-card__btn-arrow">&#8964;</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Intention",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Intention"
    }
  ],
  "blocks": [
    {
      "type": "intention_card",
      "name": "Intention Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image (optional)"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon Type (if no icon image)",
          "options": [
            { "value": "wealth", "label": "Wealth / Lotus" },
            { "value": "love", "label": "Love / Heart" },
            { "value": "protection", "label": "Protection / Shield" }
          ],
          "default": "wealth"
        },
        {
          "type": "text",
          "id": "title_chinese",
          "label": "Title (Chinese)",
          "default": "财富"
        },
        {
          "type": "text",
          "id": "subtitle_chinese",
          "label": "Subtitle (Chinese)",
          "default": "润财旺言，援进妆妆诶"
        },
        {
          "type": "text",
          "id": "title_english",
          "label": "Title (English)",
          "default": "Attract Wealth & Career Breakthroughs"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "顾功恋码"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Intention",
      "blocks": [
        {
          "type": "intention_card",
          "settings": {
            "icon_type": "wealth",
            "title_chinese": "财富",
            "subtitle_chinese": "润财旺言，援进妆妆诶",
            "title_english": "Attract Wealth & Career Breakthroughs",
            "button_label": "顾功恋码"
          }
        },
        {
          "type": "intention_card",
          "settings": {
            "icon_type": "love",
            "title_chinese": "爱繁",
            "subtitle_chinese": "拢则压境，规灰冰吕",
            "title_english": "Attract Love & Enhance Relationships",
            "button_label": "顾竹恋码"
          }
        },
        {
          "type": "intention_card",
          "settings": {
            "icon_type": "protection",
            "title_chinese": "保护",
            "subtitle_chinese": "砌 th A，肌茹诶桂",
            "title_english": "Ward Off Negativity & Shield Your Energy",
            "button_label": "魏乃忻份"
          }
        }
      ]
    }
  ]
}
{% endschema %}
