<section class="hero-banner" style="min-height: {{ section.settings.height }}px;">
  <div class="hero-banner__split">
    <div class="hero-banner__left">
      {%- if section.settings.left_image != blank -%}
        <img
          src="{{ section.settings.left_image | image_url: width: 900 }}"
          alt="{{ section.settings.left_image.alt | escape }}"
          class="hero-banner__bg-img"
          loading="eager"
          width="900"
          height="600"
        >
      {%- else -%}
        <div class="hero-banner__placeholder hero-banner__placeholder--left">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-banner__placeholder-svg' }}
        </div>
      {%- endif -%}
      <div class="hero-banner__content">
        {%- if section.settings.heading != blank -%}
          <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}" class="hero-banner__btn">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="hero-banner__right">
      {%- if section.settings.right_image != blank -%}
        <img
          src="{{ section.settings.right_image | image_url: width: 900 }}"
          alt="{{ section.settings.right_image.alt | escape }}"
          class="hero-banner__bg-img"
          loading="eager"
          width="900"
          height="600"
        >
      {%- else -%}
        <div class="hero-banner__placeholder hero-banner__placeholder--right">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'hero-banner__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Banner Height",
      "default": 600
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Background Image (Crystals / Beach)"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Background Image (Model)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Your Energy"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (Chinese)",
      "default": "开启你的专属能场"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
