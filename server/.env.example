# Copy to .env and fill in your values.
# Get API credentials from: Shopify Partners → Apps → your app → API credentials

# ── Required ──────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Public HTTPS URL of this server (no trailing slash).
# Railway sets this automatically once you deploy.
# Example: https://returns-center.up.railway.app
HOST=https://your-app.railway.app

# URL of the frontend (no trailing slash).
# GitHub Pages example: https://yourname.github.io/nilism
# Local dev: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=3001

# ── What to paste in Shopify Partners → App setup ────────────────────────────
# App URL:              https://your-app.railway.app/auth/shopify
# Allowed redirect URL: https://your-app.railway.app/auth/shopify/callback
#
# GDPR webhooks (Partners → App setup → GDPR webhooks):
#   Customer data request: https://your-app.railway.app/webhooks/customers.data_request
#   Customer redact:       https://your-app.railway.app/webhooks/customers.redact
#   Shop redact:           https://your-app.railway.app/webhooks/shop.redact
