# Copy this to .env and fill in your values
# Get these from your Shopify Partners dashboard -> Your App -> API credentials

SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# The public URL of this server (e.g. https://your-app.railway.app)
HOST=https://your-app.railway.app

# The URL of your frontend (e.g. https://yourstore.github.io/nilism or http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Port to listen on (Railway sets this automatically)
PORT=3001
