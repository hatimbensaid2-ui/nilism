# Copy to .env and fill in your values.
# Get API credentials from: Shopify Partners → Apps → your app → API credentials

# ── Required ──────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Public HTTPS URL of this server (no trailing slash).
HOST=https://nilism-production-1996.up.railway.app

# Admin panel password — change this to something secure before going live!
ADMIN_PASSWORD=change_me_before_deploy

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=3001

# ── What to paste in Shopify Partners → App setup ────────────────────────────
# App URL:              https://nilism-production-1996.up.railway.app/auth/shopify
# Allowed redirect URL: https://nilism-production-1996.up.railway.app/auth/shopify/callback
#
# GDPR webhooks (Partners → App setup → GDPR webhooks):
#   Customer data request: https://nilism-production-1996.up.railway.app/webhooks/customers.data_request
#   Customer redact:       https://nilism-production-1996.up.railway.app/webhooks/customers.redact
#   Shop redact:           https://nilism-production-1996.up.railway.app/webhooks/shop.redact
