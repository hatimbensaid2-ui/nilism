[
  {
    "name": "theme_info",
    "theme_name": "Nilism",
    "theme_version": "2.0.0",
    "theme_author": "Nilism",
    "theme_documentation_url": "https://nilism.com",
    "theme_support_url": "https://nilism.com/support"
  },
  {
    "name": "Background",
    "settings": [
      {
        "type": "image_picker",
        "id": "bg_image",
        "label": "Page background image",
        "info": "Applies to every section on the page. Recommended: 1920×1200px JPG."
      },
      {
        "type": "range",
        "id": "bg_overlay",
        "min": 0,
        "max": 85,
        "step": 5,
        "unit": "%",
        "label": "Background overlay darkness",
        "default": 55,
        "info": "Darkens the image so text stays readable. 0 = image only, 85 = very dark."
      },
      {
        "type": "checkbox",
        "id": "bg_fixed",
        "label": "Fixed background (parallax effect)",
        "default": true,
        "info": "Background stays in place while the page scrolls."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Fallback page color",
        "info": "Used when no background image is set.",
        "default": "#0E0B22"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#F0E8D4"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Accent colour",
        "default": "#C9963B"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border colour",
        "default": "#261A55"
      },
      {
        "type": "color",
        "id": "color_header_bg",
        "label": "Header background",
        "default": "#0A0720"
      },
      {
        "type": "color",
        "id": "color_footer_bg",
        "label": "Footer background",
        "default": "#07041A"
      },
      {
        "type": "color",
        "id": "color_button_bg",
        "label": "Button colour",
        "default": "#C9963B"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "range",
        "id": "font_body_size",
        "min": 13,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Body font size",
        "default": 16
      }
    ]
  },
  {
    "name": "Logo and favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 140
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32 x 32px .png recommended"
      }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main menu",
        "default": "main-menu"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "page", "label": "Cart page" },
          { "value": "drawer", "label": "Drawer" }
        ],
        "default": "page"
      }
    ]
  }
]
