[
  {
    "name": "theme_info",
    "theme_name": "AoSharma",
    "theme_version": "1.0.0",
    "theme_author": "AoSharma",
    "theme_documentation_url": "https://aosharma.com",
    "theme_support_url": "https://aosharma.com/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#F5F0EB"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#2C1F10"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Accent (Gold)",
        "default": "#B8936A"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#D4C4B0"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "cormorant_garamond_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "jost_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "label": "Body font size",
        "default": 16
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "32 x 32px .png recommended"
      }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main menu",
        "default": "main-menu"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "page",   "label": "Cart page" },
          { "value": "drawer", "label": "Drawer" }
        ],
        "default": "page"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram link"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok link"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook link"
      },
      {
        "type": "url",
        "id": "social_pinterest",
        "label": "Pinterest link"
      }
    ]
  }
]
